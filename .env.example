# App: application identity and runtime mode.
APP_NAME=DestinyCommand
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# App locale: language defaults used by Laravel.
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance mode: controls how Laravel handles maintenance windows.
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP CLI server: optional worker count for local development.
# PHP_CLI_SERVER_WORKERS=4

# DestinyCommand: Bungie API key for all Destiny API requests.
BUNGIE_API_KEY=

# DestinyCommand: Bungie OAuth client id.
BUNGIE_CLIENT_ID=

# DestinyCommand: Bungie OAuth client secret.
BUNGIE_CLIENT_SECRET=

# DestinyCommand: Bungie OAuth callback URL, typically /auth/bungie/callback.
BUNGIE_REDIRECT_URI=

# DestinyCommand: optional Bungie application id used in the User-Agent string.
BUNGIE_APP_ID=

# DestinyCommand: app version used in the User-Agent string.
APP_VERSION=local

# DestinyCommand: optional semicolon-separated moderator hashes for privileged commands.
MODERATOR_KEYS=

# DestinyCommand: optional Origin header sent to Bungie. Leave blank unless your API key is bound to a specific origin.
DESTINYCOMMAND_REQUEST_ORIGIN=

# DestinyCommand: User-Agent sent to Bungie and related upstream services.
DESTINYCOMMAND_USER_AGENT="DestinyCommand/laravel13 (+${APP_URL})"

# Bcrypt: password hashing work factor.
BCRYPT_ROUNDS=12

# Logging: default channels and verbosity.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: default local setup uses SQLite. Swap to mysql if preferred.
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=destinycommand
# DB_USERNAME=root
# DB_PASSWORD=

# Session: how user session data is stored.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting: default event broadcast transport.
BROADCAST_CONNECTION=log

# Filesystem: default disk for local file storage.
FILESYSTEM_DISK=local

# Queue: default queue backend for async jobs.
QUEUE_CONNECTION=sync

# Cache: default cache store and optional key prefix.
CACHE_STORE=file
# CACHE_PREFIX=

# Memcached: optional cache backend host.
MEMCACHED_HOST=127.0.0.1

# Redis: optional cache/queue/session backend.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: outbound mail transport configuration.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS: optional object storage credentials.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite: frontend app name exposed to built assets.
VITE_APP_NAME="${APP_NAME}"
